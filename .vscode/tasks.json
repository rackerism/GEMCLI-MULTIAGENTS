{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Initialize MAS - 5 Agents",
      "type": "shell",
      "command": "${command:terminal.sendSequence}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "windows": {
        "command": "setup.bat"
      },
      "linux": {
        "command": "bash",
        "args": ["setup.sh"]
      },
      "osx": {
        "command": "bash",
        "args": ["setup.sh"]
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Verify Gemini CLI Setup",
      "type": "shell",
      "command": "gemini",
      "args": ["--version"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Test Gemini CLI Authentication",
      "type": "shell",
      "command": "gemini",
      "args": ["\"Hello from MAS setup!\""],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
